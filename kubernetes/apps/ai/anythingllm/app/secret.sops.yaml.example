# IMPORTANT: plaintext template — do NOT commit as-is.
# Copy to secret.sops.yaml, fill values, encrypt, then uncomment
# the resource entry in kustomization.yaml.
#
#   cp secret.sops.yaml.example secret.sops.yaml
#   # edit values
#   task sops:encrypt-file file=kubernetes/apps/ai/anythingllm/app/secret.sops.yaml
#   task sops:verify
#
# JWT_SECRET: generate with: openssl rand -hex 32
# LITELLM_VIRTUAL_KEY: mint via POST /key/generate against LiteLLM admin
#   API with model allow-list (local-balanced, local-embed, etc.)
# INIT_POSTGRES_*: same pattern as LiteLLM init-db.
#   INIT_POSTGRES_SUPER_PASS: from cloudnative-pg-secret.password in databases ns
#   INIT_POSTGRES_PASS: generate with: openssl rand -hex 24
# DATABASE_CONNECTION_STRING: postgresql://anythingllm:<INIT_POSTGRES_PASS>@postgres-rw.databases.svc.cluster.local:5432/anythingllm
apiVersion: v1
kind: Secret
metadata:
  name: anythingllm-secret
type: Opaque
stringData:
  JWT_SECRET: "REPLACE_ME_openssl_rand_-hex_32"
  LITELLM_VIRTUAL_KEY: "sk-REPLACE_ME_mint_via_litellm_key_generate"

  # Postgres init-db (creates anythingllm role + DB on CNPG cluster)
  INIT_POSTGRES_HOST: "postgres-rw.databases.svc.cluster.local"
  INIT_POSTGRES_DBNAME: "anythingllm"
  INIT_POSTGRES_USER: "anythingllm"
  INIT_POSTGRES_PASS: "REPLACE_ME_openssl_rand_-hex_24"
  INIT_POSTGRES_SUPER_USER: "postgres"
  INIT_POSTGRES_SUPER_PASS: "REPLACE_ME_from_cloudnative-pg-secret_password_field"

  # Full connection string for AnythingLLM (uses INIT_POSTGRES_* values above)
  DATABASE_CONNECTION_STRING: "postgresql://anythingllm:REPLACE_ME_PASS@postgres-rw.databases.svc.cluster.local:5432/anythingllm"
