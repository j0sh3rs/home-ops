# IMPORTANT: plaintext template — do NOT commit as-is.
# Copy, fill, encrypt:
#   cp secret.sops.yaml.example secret.sops.yaml
#   # edit values below
#   task sops:encrypt-file \
#     file=kubernetes/apps/ai/anythingllm/app/secret.sops.yaml
#   task sops:verify
#   # uncomment - ./secret.sops.yaml in kustomization.yaml
#
# JWT_SECRET: openssl rand -hex 32
# LITELLM_VIRTUAL_KEY: POST /key/generate to LiteLLM admin API
#   model_list: [local-balanced, local-embed, local-rerank, local-large]
apiVersion: v1
kind: Secret
metadata:
  name: anythingllm-secret
type: Opaque
stringData:
  JWT_SECRET: "REPLACE_ME_openssl_rand_-hex_32"
  LITELLM_VIRTUAL_KEY: "sk-REPLACE_ME_mint_via_litellm_key_generate"
