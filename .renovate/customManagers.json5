{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: "Process annotated dependencies",
      fileMatch: [
        "(^|/).+\\.env$",
        "(^|/).+\\.sh$",
        "(^|/).+\\.ya?ml(?:\\.j2)?$",
      ],
      matchStrings: [
        // # renovate: datasource=github-releases depName=k3s-io/k3s
        // k3s_release_version: &version v1.29.0+k3s1
        // # renovate: datasource=helm depName=cilium repository=https://helm.cilium.io
        // version: 1.15.1
        // # renovate: datasource=docker depName=ghcr.io/siderolabs/kubelet
        // KUBERNETES_VERSION=v1.31.1
        // # renovate: datasource=docker depName=docker.io/rocm/k8s-device-plugin/labeller versioning=regex:^labeller-(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)\.(?<build>\d+)$
        // tag: labeller-1.31.0.10
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: (?:repository|registryUrl)=(?<registryUrl>\\S+))?(?: versioning=(?<versioning>\\S+))?\\n.+(:\\s|=)(&\\S+\\s)?(?<currentValue>\\S+)",
        // # renovate: datasource=docker depName=ghcr.io/prometheus-operator/prometheus-operator
        // https://raw.githubusercontent.com/prometheus-operator/prometheus-operator/v0.80.0/example/prometheus-operator-crd/monitoring.coreos.com_alertmanagerconfigs.yaml
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+/(?<currentValue>(v|\\d)[^/]+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
    {
      customType: "regex",
      description: "CNPG ClusterImageCatalog — track image DIGEST only, never the tag",
      // The CNPG ClusterImageCatalog stores `major: <int>` (a PG major
      // version) directly above the pinned `image:`. The generic annotation
      // manager above captured `major: 18` as currentValue and rewrote it to
      // `18.4`, breaking the catalog (PR #419). So this file carries NO inline
      // `# renovate:` annotation; instead we match the `image:` line directly
      // and capture tag + digest. A packageRule in autoMerge.json5 disables
      // tag (major/minor/patch) bumps for this depName, leaving digest-only —
      // major/distro hops stay manual per the file's documented procedure.
      fileMatch: [
        "(^|/)kubernetes/apps/databases/cloudnative-pg/cluster/imagecatalog\\.ya?ml$",
      ],
      matchStrings: [
        "image:\\s+(?<depName>ghcr\\.io/cloudnative-pg/postgresql):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)",
      ],
      datasourceTemplate: "docker",
      versioningTemplate: "loose",
    },
    {
      customType: "regex",
      description: "Bump aqua-managed tool versions in .mise.toml",
      // Renovate's built-in `mise` manager handles `tools = "x"` syntax in
      // .tool-versions but not the .mise.toml `[tools]` table with quoted
      // `aqua:<owner>/<repo>` keys. Match those explicitly via custom regex.
      fileMatch: [
        "(^|/)\\.mise\\.toml$",
      ],
      matchStrings: [
        // "aqua:budimanjojo/talhelper" = "3.1.10"
        // "aqua:siderolabs/talos" = "1.13.2"
        "\"aqua:(?<depName>[^\"]+)\"\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      datasourceTemplate: "github-releases",
      // Aqua tool versions are typically the upstream release tag without
      // the leading 'v' (e.g. talos 1.13.2 vs release tag v1.13.2). Add
      // the prefix when generating the comparison so Renovate matches.
      extractVersionTemplate: "^v?(?<version>.+)$",
    },
  ],
}
