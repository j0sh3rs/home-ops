{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Actions Runner Controller Group",
      groupName: "Actions Runner Controller",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/gha-runner-scale-set-controller/", "/gha-runner-scale-set/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Cert-Manager Group - Critical Infrastructure",
      groupName: "Cert-Manager",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/cert-manager/"],
      stabilityDays: 7,
      automerge: false,
      labels: ["type/infrastructure", "risk/high"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Cilium Group - Critical Infrastructure (CNI)",
      groupName: "Cilium",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/cilium/"],
      stabilityDays: 7,
      automerge: false,
      labels: ["type/infrastructure", "risk/critical"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "CoreDNS Group - Critical Infrastructure",
      groupName: "CoreDNS",
      matchDatasources: ["docker"],
      matchPackageNames: ["/coredns/"],
      stabilityDays: 7,
      automerge: false,
      labels: ["type/infrastructure", "risk/critical"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Flux Operator Group - Critical Infrastructure",
      groupName: "Flux Operator",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/flux-operator/", "/flux-instance/"],
      stabilityDays: 7,
      automerge: false,
      labels: ["type/infrastructure", "risk/critical"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Spegel Group",
      groupName: "Spegel",
      matchDatasources: ["docker"],
      matchPackageNames: ["/spegel/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      // Groups traefik chart (OCI) + traefik proxy image together so they are
      // always bumped in the same PR. Chart 40.x caps the proxy image at the
      // minor version it shipped with (requirements.yaml gate) so independent
      // auto-merge of the image alone will break HelmRelease reconciliation.
      description: "Traefik - Ingress Infrastructure",
      groupName: "Traefik",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/traefik/"],
      stabilityDays: 3,
      automerge: false,
      labels: ["type/infrastructure", "risk/high"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Envoy Gateway - High-Risk Infrastructure",
      groupName: "Envoy Gateway",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/envoy-gateway/", "/envoyproxy/"],
      stabilityDays: 5,
      automerge: false,
      labels: ["type/infrastructure", "risk/high"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "OpenEBS - Storage Infrastructure",
      groupName: "OpenEBS",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/openebs/"],
      stabilityDays: 5,
      automerge: false,
      labels: ["type/infrastructure", "risk/high"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Tetragon - Security Infrastructure",
      groupName: "Tetragon",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/tetragon/"],
      stabilityDays: 5,
      automerge: false,
      labels: ["type/security", "risk/high"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Platform Services - Monitoring Stack",
      groupName: "Monitoring Stack",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: [
        "/kube-prometheus-stack/",
        "/grafana/",
        "/thanos/",
        "/victoria-logs/",
        "/prometheus-operator/",
      ],
      stabilityDays: 3,
      automerge: false,
      labels: ["type/platform", "risk/medium"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Platform Services - Database Operators",
      groupName: "Database Operators",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/cloudnative-pg/", "/dragonfly-operator/", "/postgresql/"],
      stabilityDays: 3,
      automerge: false,
      labels: ["type/platform", "risk/medium"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "OAuth2 Proxy - Security Infrastructure",
      groupName: "OAuth2 Proxy",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/oauth2-proxy/"],
      stabilityDays: 3,
      automerge: false,
      labels: ["type/security", "risk/high"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "AMD GPU stack - device plugin chart + plugin/labeller images",
      groupName: "AMD GPU",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: [
        "amd-gpu",
        "/rocm\\/k8s-device-plugin/",
      ],
      labels: ["type/platform", "risk/medium"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "AI Stack - LiteLLM gateway + local inference + UI + workflow automation",
      groupName: "AI Stack",
      matchDatasources: ["docker", "helm", "github-releases"],
      matchPackageNames: [
        "/berriai\\/litellm/",
        "/berriai\\/litellm-helm/",
        "/open-webui\\/open-webui/",
        "/mostlygeek\\/llama-swap/",
        "n8nio/n8n",
      ],
      stabilityDays: 3,
      labels: ["type/app", "risk/low"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "OpenCode Extensions - skill bundles + npm plugins (#486)",
      groupName: "OpenCode Extensions",
      matchDatasources: ["github-releases", "npm"],
      matchPackageNames: [
        "JuliusBrussee/caveman",
        "affaan-m/ECC",
        "@franlol/opencode-md-table-formatter",
      ],
      stabilityDays: 3,
      labels: ["type/app", "risk/low"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "llama-swap: only allow vulkan-b tagged builds",
      matchPackageNames: ["ghcr.io/mostlygeek/llama-swap"],
      allowedVersions: "/.*-vulkan-b.*/",
      automerge: false,
      groupName: null,
    },
    {
      description: "n8n: pin to 2.23.x series",
      matchPackageNames: ["n8nio/n8n"],
      allowedVersions: "/^2\\.23\\./",
      automerge: false,
    },
  ],
}
