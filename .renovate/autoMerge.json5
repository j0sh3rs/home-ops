{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto-merge all non-major updates",
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge Helm chart updates as PRs for visibility",
      matchDatasources: ["helm"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge GitHub Actions with minimum release age",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
      // Out of scope for the flux-diff check (it only triggers on
      // kubernetes/**/*.yaml paths) — leave ignoreTests true so these
      // don't wait forever on a check that never runs.
      ignoreTests: true,
    },
    {
      description: "Block automerge for major version updates",
      matchUpdateTypes: ["major"],
      automerge: false,
    },
    {
      // CNPG ClusterImageCatalog: track the image DIGEST only. Tag bumps
      // (major/minor/patch) are disabled so Renovate can't roll the PG
      // version or distro out from under the running cluster — those are
      // manual, dedicated PRs (see imagecatalog.yaml header). Digest-only
      // rebuilds of the SAME tag auto-merge. Fixes the broken PR #419 path.
      description: "CNPG postgresql image — digest-only, no tag bumps",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/cloudnative-pg/postgresql"],
      matchUpdateTypes: ["major", "minor", "patch"],
      enabled: false,
    },
    {
      description: "CNPG postgresql image — auto-merge digest rebuilds",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/cloudnative-pg/postgresql"],
      matchUpdateTypes: ["digest"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: false,
    },
  ],
}
